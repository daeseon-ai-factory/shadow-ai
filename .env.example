# Copy to .env and fill in. .env is gitignored.

# ===== Backend =====
JWT_SECRET=change-me-256-bits-of-random-base64

# AI provider: "gemini" (default, free tier) or "claude". Fill the matching key below.
AI_PROVIDER=gemini
GEMINI_API_KEY=                                   # used when AI_PROVIDER=gemini (default); analysis disabled if blank
ANTHROPIC_API_KEY=                                # used when AI_PROVIDER=claude

# Local Postgres (Docker compose default)
DATABASE_URL=jdbc:postgresql://localhost:5434/tubeshadow
DATABASE_USERNAME=tubeshadow
DATABASE_PASSWORD=tubeshadow

# CORS — comma-separated origin patterns
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:*

# ===== Production extras (only needed in AWS) =====
# RECORDING_STORAGE=s3
# RECORDING_S3_BUCKET=tubeshadow-recordings-{account-id}
# AWS_REGION=ca-central-1

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:8080
