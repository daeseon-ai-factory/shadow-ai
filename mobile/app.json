{
  "expo": {
    "name": "Mimi",
    "slug": "mimi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mimi",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "ai.daeseon.mimi",
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Mimi to recognize your spoken English so it can check your interview answers.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Mimi accesses photos only to display images within the app."
      }
    },
    "android": {
      "package": "ai.daeseon.mimi",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/logo-glow.png",
          "imageWidth": 160
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Mimi to use the microphone to record your shadowing practice."
        }
      ],
      "expo-localization",
      [
        "expo-speech-recognition",
        {
          "speechRecognitionPermission": "Allow Mimi to recognize your spoken English so it can check your interview answers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "41c3e688-ef54-4125-9c80-006486dc4c84"
      }
    },
    "owner": "daeseonyoo"
  }
}
